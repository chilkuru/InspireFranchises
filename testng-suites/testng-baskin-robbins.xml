<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  testng-baskin-robbins.xml — Runs only Baskin-Robbins-related tests
  (common brand tests TC-B-01..TC-B-12 + Baskin-Robbins-specific TC-BR-01..TC-BR-10).

  Usage:
    .\mvnw.cmd clean test -P baskin-robbins
    .\mvnw.cmd clean test -P baskin-robbins -Dheadless=true
    .\mvnw.cmd clean test -P baskin-robbins -Dgroups=smoke
-->
<suite name="Inspire Brands – Baskin-Robbins Suite"
       verbose="2"
       parallel="false">

    <listeners>
        <listener class-name="com.inspire.listeners.ExtentReportListener"/>
    </listeners>

    <!-- ── Smoke Tests — fast sanity pass ──────────────────────────────────── -->
    <test name="Baskin-Robbins – Smoke Tests" preserve-order="true">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.inspire.tests.brands.BaskinRobbinsTest"/>
        </classes>
    </test>

    <!-- ── Full Regression — all Baskin-Robbins tests ───────────────────────── -->
    <test name="Baskin-Robbins – Full Regression" preserve-order="true">
        <groups>
            <run>
                <include name="regression"/>
                <exclude name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.inspire.tests.brands.BaskinRobbinsTest"/>
        </classes>
    </test>

</suite>
